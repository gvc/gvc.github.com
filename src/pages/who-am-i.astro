---
import Layout from '../layouts/Layout.astro';
---

<Layout title="~/gvc // WHO_AM_I" activeNav="who-am-i">
  <Fragment slot="head">
    <style>
      .scanline-effect {
        background: linear-gradient(
          to bottom,
          transparent 50%,
          rgba(0, 255, 127, 0.05) 50%
        );
        background-size: 100% 4px;
      }
      .noise-overlay {
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
        opacity: 0.03;
        pointer-events: none;
      }
    </style>
  </Fragment>

  <div class="fixed inset-0 noise-overlay z-0"></div>
  <main
    class="pt-28 pb-32 px-6 md:px-12 min-h-screen max-w-7xl mx-auto relative z-10 flex-grow"
  >
    <!-- Header Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-12">
      <!-- Profile Column -->
      <div class="lg:col-span-4 flex flex-col gap-6">
        <div class="relative group">
          <!-- Photo Container with UI Accents -->
          <div
            class="aspect-[4/5] bg-surface-container-lowest border-2 border-primary-container relative overflow-hidden"
          >
            <img
              alt="Profile Portrait"
              class="w-full h-full object-cover grayscale brightness-90 contrast-125"
              src="/profile.webp"
            />
            <div
              class="absolute inset-0 scanline-effect pointer-events-none opacity-40"
            ></div>
            <div
              class="absolute inset-0 border-[16px] border-surface-container-lowest/20 pointer-events-none"
            ></div>
            <!-- UI Overlays -->
            <div class="absolute top-4 left-4 flex flex-col gap-1">
              <div
                class="bg-primary-container text-on-primary text-[8px] px-2 py-0.5 font-black uppercase tracking-widest"
              >
                ID: 8842-X
              </div>
              <div
                class="bg-surface-container-highest text-primary-container text-[8px] px-2 py-0.5 font-bold uppercase tracking-tighter"
              >
                SIGNAL_LOCKED
              </div>
            </div>
            <div
              class="absolute bottom-4 right-4 text-primary-container opacity-50"
            >
              <span class="material-symbols-outlined scale-150">filter_center_focus</span>
            </div>
          </div>
          <!-- Meta Info Under Profile -->
          <!-- <div class="mt-4 grid grid-cols-2 gap-2"> -->
          <!--   <div -->
          <!--     class="bg-surface-container p-3 border-t-2 border-primary-container" -->
          <!--   > -->
          <!--     <span -->
          <!--       class="block text-[8px] text-on-surface-variant font-black uppercase mb-1" -->
          <!--     >Access_Code</span> -->
          <!--     <span class="text-xs font-mono font-bold text-primary-container">#99-ALPHA-Z</span> -->
          <!--   </div> -->
          <!--   <div -->
          <!--     class="bg-surface-container p-3 border-t-2 border-secondary-container" -->
          <!--   > -->
          <!--     <span -->
          <!--       class="block text-[8px] text-on-surface-variant font-black uppercase mb-1" -->
          <!--     >Data_Weight</span> -->
          <!--     <span class="text-xs font-mono font-bold text-secondary-container">1.4 TB</span> -->
          <!--   </div> -->
          <!-- </div> -->
        </div>
      </div>
      <!-- Subject Details Column -->
      <div class="lg:col-span-8 flex flex-col justify-between">
        <div>
          <div class="flex items-center gap-4 mb-4">
            <div class="h-[2px] w-12 bg-primary-container"></div>
            <span
              class="text-on-surface-variant text-[10px] tracking-[0.4em] uppercase font-black"
            >CLASSIFIED_DOSSIER_v4.2</span>
          </div>
          <h1
            class="text-6xl md:text-8xl font-black font-headline tracking-tighter uppercase leading-[0.85] mb-8"
          >
            GUILHERME<br />CARVALHO
          </h1>
          <div class="text-on-surface-variant text-base leading-relaxed max-w-2xl font-medium space-y-4">
            <p>
              I joined <a href="https://vtex.com" target="_blank" rel="noopener" class="text-primary-container hover:underline">VTEX</a> in 2021 as an Engineering Manager, leading the team that built <a href="https://faststore.dev" target="_blank" rel="noopener" class="text-primary-container hover:underline">FastStore</a> — VTEX's
              modern storefront framework. In 2023 I moved into a Staff Software Engineer role, focused on
              bringing the FastStore platform to other products inside VTEX, redefining it for an AI-first world,
              and helping raise code delivery quality across the vertical. Most of my work here lives in
              Node.js, TypeScript, and distributed systems.
            </p>
            <p>
              Before that, I co-founded <a href="https://web.archive.org/web/20210618065028/https://guava.software/" target="_blank" rel="noopener" class="text-primary-container hover:underline">Guava Software</a> in 2011 — a boutique Ruby/Rails development studio
              based in Recife. For a decade I acted as lead developer across a wide range of client projects:
              True &amp; Co, MetaMaster, <a href="https://petplate.com" target="_blank" rel="noopener" class="text-primary-container hover:underline">PetPlate</a>, Endossa, and others spanning e-commerce, fintech, and civic tech.
              Our stack centered on Ruby on Rails and Python on the backend, Vue.js and React on the frontend.
              VTEX acquired Guava in 2021.
            </p>
            <p>
              I studied Computer Science at <a href="https://cin.ufpe.br" target="_blank" rel="noopener" class="text-primary-container hover:underline">Centro de Informática, UFPE</a>, where I also completed my Master's
              focused on ensemble methods for machine learning. That work led to a couple of published papers —
              <a href="https://ieeexplore.ieee.org/document/6033472" target="_blank" rel="noopener" class="text-primary-container hover:underline">on pedestrian detection using PCA-based reconstruction</a> and <a href="https://www.inf.ufpr.br/lesoliveira/download/PRL2016.pdf" target="_blank" rel="noopener" class="text-primary-container hover:underline">on combining diversity measures for
              ensemble pruning</a> — in collaboration with researchers at UFPE and UFPR.
            </p>
          </div>
        </div>
      </div>
    </div>
    <!-- Bento Grid Main Content -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      <!-- System Capabilities (Technical Meters) -->
      <section
        class="lg:col-span-5 bg-surface-container-low p-8 border-t-4 border-secondary-container relative"
      >
        <div class="flex justify-between items-center mb-10">
          <h2
            class="font-headline font-black text-xl uppercase tracking-widest"
          >
            TECH_STACK
          </h2>
          <span class="material-symbols-outlined text-secondary-container opacity-60">memory</span>
        </div>
        <div class="space-y-4">
          <div class="flex items-center gap-3">
            <span class="w-1.5 h-1.5 bg-secondary-container"></span>
            <span class="text-[10px] font-black tracking-widest uppercase">Node.js_/_Backend</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="w-1.5 h-1.5 bg-secondary-container"></span>
            <span class="text-[10px] font-black tracking-widest uppercase">Software_Design</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="w-1.5 h-1.5 bg-secondary-container"></span>
            <span class="text-[10px] font-black tracking-widest uppercase">Ruby_/_Rails</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="w-1.5 h-1.5 bg-secondary-container"></span>
            <span class="text-[10px] font-black tracking-widest uppercase">Machine_Learning</span>
          </div>
        </div>
        <div
          class="mt-16 p-6 bg-background border border-surface-container text-xs font-mono text-on-surface-variant/80 leading-relaxed italic relative"
        >
          <span
            class="absolute -top-3 left-4 bg-background px-2 text-[8px] font-black text-secondary-container"
          >ASSESSMENT_NOTE</span>
          "14+ years of deployment across startups and enterprise. From
          co-founding a dev studio to staff-level engineering at scale.
          MSc in Machine Learning. Recommend for critical system operations."
        </div>
      </section>
      <!-- Deployment History (Timeline) -->
      <section class="lg:col-span-7 bg-surface-container-high p-8 relative">
        <div class="flex justify-between items-center mb-10">
          <h2
            class="font-headline font-black text-xl uppercase tracking-widest"
          >
            DEPLOYMENT_HISTORY
          </h2>
          <span class="material-symbols-outlined text-tertiary-fixed-dim">history_edu</span>
        </div>
        <div
          class="relative pl-10 border-l border-surface-container-highest space-y-12"
        >
          <!-- Entry 1 -->
          <div class="relative">
            <div
              class="absolute -left-[45px] top-1 bg-tertiary-fixed-dim text-on-tertiary p-1 rounded-sm shadow-[0_0_10px_rgba(181,202,214,0.3)]"
            >
              <span class="material-symbols-outlined text-sm">settings_suggest</span>
            </div>
            <div
              class="flex flex-col md:flex-row md:justify-between items-baseline gap-2 mb-2"
            >
              <h3 class="text-xl font-black tracking-tight uppercase">
                VTEX
              </h3>
              <span
                class="text-[10px] font-mono bg-background px-3 py-1 border border-surface-container text-tertiary-fixed-dim"
              >SEP 2023 // PRESENT</span>
            </div>
            <p
              class="text-[11px] font-bold text-tertiary-fixed-dim uppercase tracking-widest mb-3"
            >
              Staff Software Engineer
            </p>
            <p
              class="text-sm text-on-surface-variant leading-relaxed font-medium"
            >
              Building and scaling commerce platform infrastructure.
              Node.js, Software Design, and full-stack architecture
              in a hybrid setup based in Recife, Brazil.
            </p>
          </div>
          <!-- Entry 2 -->
          <div class="relative">
            <div
              class="absolute -left-[45px] top-1 bg-surface-container-highest text-on-surface-variant p-1 rounded-sm"
            >
              <span class="material-symbols-outlined text-sm">monitoring</span>
            </div>
            <div
              class="flex flex-col md:flex-row md:justify-between items-baseline gap-2 mb-2"
            >
              <h3 class="text-xl font-black tracking-tight uppercase">
                VTEX
              </h3>
              <span
                class="text-[10px] font-mono bg-background px-3 py-1 border border-surface-container"
              >SEP 2021 // MAR 2024</span>
            </div>
            <p
              class="text-[11px] font-bold text-on-surface-variant/60 uppercase tracking-widest mb-3"
            >
              Engineering Manager
            </p>
            <p
              class="text-sm text-on-surface-variant leading-relaxed font-medium"
            >
              Led engineering teams delivering commerce solutions at scale.
              Drove technical strategy, team growth, and cross-functional
              alignment across product and platform initiatives.
            </p>
          </div>
          <!-- Entry 3 -->
          <div class="relative">
            <div
              class="absolute -left-[45px] top-1 bg-surface-container-highest text-on-surface-variant p-1 rounded-sm"
            >
              <span class="material-symbols-outlined text-sm">code</span>
            </div>
            <div
              class="flex flex-col md:flex-row md:justify-between items-baseline gap-2 mb-2"
            >
              <h3 class="text-xl font-black tracking-tight uppercase">
                Guava_Software
              </h3>
              <span
                class="text-[10px] font-mono bg-background px-3 py-1 border border-surface-container"
              >JAN 2011 // AUG 2021</span>
            </div>
            <p
              class="text-[11px] font-bold text-on-surface-variant/60 uppercase tracking-widest mb-3"
            >
              Co-founder & Software Developer
            </p>
            <p
              class="text-sm text-on-surface-variant leading-relaxed font-medium"
            >
              Co-founded a Ruby/Rails development studio delivering
              high-quality, maintainable software. Helped businesses build
              the technology they need using best-fit tools and architectures.
            </p>
          </div>
        </div>
      </section>
    </div>

  </main>
</Layout>
