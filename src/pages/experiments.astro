---
import Layout from '../layouts/Layout.astro';
---

<Layout title="TACTICAL_TERMINAL // EXPERIMENTS" activeNav="experiments">
  <Fragment slot="head">
    <style>
      .recessed-well {
        box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.5);
      }
      .pulse-dot {
        box-shadow: 0 0 8px #00ff7f;
      }
    </style>
  </Fragment>

  <main class="max-w-7xl mx-auto pt-24 pb-20 px-6 min-h-screen flex-grow">
    <!-- Header & Search Cluster -->
    <header class="mb-12">
      <div
        class="flex flex-col md:flex-row md:items-end justify-between gap-6"
      >
        <div>
          <div class="flex items-center space-x-2 mb-2">
            <span class="w-2 h-2 rounded-full bg-primary pulse-dot"></span>
            <span
              class="text-on-surface-variant font-label text-[10px] tracking-widest uppercase"
            >ACTIVE_DIRECTORY / EXPERIMENTS</span>
          </div>
          <h1
            class="text-5xl md:text-7xl font-black font-headline tracking-tighter text-on-surface uppercase leading-none"
          >
            EXPERIMENT_LOG
          </h1>
        </div>
        <!-- <div class="w-full md:w-96">
          <div
            class="bg-surface-container-lowest p-1 flex items-center border-b-2 border-primary-fixed"
          >
            <span
              class="material-symbols-outlined text-primary-fixed px-2"
            >search</span>
            <input
              class="bg-transparent border-none focus:ring-0 text-primary-fixed placeholder:text-outline-variant font-label text-xs w-full uppercase tracking-widest"
              placeholder="QUERY_DATABASE..."
              type="text"
            />
          </div>
          <div class="flex gap-2 mt-4 overflow-x-auto pb-2 no-scrollbar">
            <button
              class="px-3 py-1 bg-surface-container-high text-primary-fixed border border-primary-fixed/30 text-[9px] font-bold tracking-widest uppercase"
            >
              SYSTEMS
            </button>
            <button
              class="px-3 py-1 bg-surface-container-low text-on-surface-variant text-[9px] font-bold tracking-widest uppercase hover:bg-surface-container-high transition-colors"
            >
              INFRA
            </button>
            <button
              class="px-3 py-1 bg-surface-container-low text-on-surface-variant text-[9px] font-bold tracking-widest uppercase hover:bg-surface-container-high transition-colors"
            >
              SECURITY
            </button>
            <button
              class="px-3 py-1 bg-surface-container-low text-on-surface-variant text-[9px] font-bold tracking-widest uppercase hover:bg-surface-container-high transition-colors"
            >
              UI/UX
            </button>
          </div>
        </div> -->
      </div>
    </header>
    <!-- Project Grid (Asymmetric Bento) -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-4">
      <!-- Featured Project 1 -->
      <div
        class="md:col-span-8 group relative bg-surface-container-low overflow-hidden hover:ring-2 hover:ring-secondary-container transition-all duration-300"
      >
        <div
          class="absolute inset-0 bg-gradient-to-t from-surface-container-lowest via-transparent to-transparent z-10 opacity-90"
        ></div>
        <img
          alt="Server Infrastructure"
          class="w-full h-96 object-cover opacity-60 group-hover:scale-105 transition-transform duration-500"
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuBLfLjJ00Xx3cOy4U83g6j_CiOlz0OX66U3vuN59x5jq4q_zSRdUOlolFxBFxHA7v3w7VOWVLzWnRN5n4dMa2-AFSR6OqPrT9IVVQImIeKAZYsCbrfXfom6KvYBIjBNVLsRluR5TYpR6LIB_2AomzkYkznwxfrAKK2u1KtuWAFeU3Y-oJSsHnVFNgG91ZVzCtmKWXETcmbi1cEvbOwEwFFa029mb-pkYxKU3PLDBn0LZ1nVLLTVayC0y3P0ihyLttekhK3xS75m4go"
        />
        <div class="absolute bottom-0 left-0 p-8 z-20 w-full">
          <div class="flex justify-between items-end">
            <div class="max-w-xl">
              <span
                class="text-secondary-container font-label text-[10px] tracking-[0.3em] font-bold uppercase mb-2 block"
              >PROJECT_ID: NEURAL_LINK</span>
              <h2
                class="text-3xl font-black font-headline text-on-surface uppercase tracking-tight mb-4"
              >
                Autonomous Mesh Protocol
              </h2>
              <p
                class="text-on-surface-variant text-sm font-body leading-relaxed mb-6 opacity-0 group-hover:opacity-100 translate-y-4 group-hover:translate-y-0 transition-all duration-300"
              >
                Implementation of a self-healing decentralized network cluster
                for high-latency environments. Leveraged edge computing nodes
                and low-power RF transmissions.
              </p>
              <div
                class="flex gap-4 opacity-0 group-hover:opacity-100 transition-all delay-100"
              >
                <div class="bg-surface-container-highest px-4 py-2">
                  <div class="text-[9px] text-outline uppercase font-bold">Latency</div>
                  <div class="text-primary-fixed font-headline font-bold">2.4ms</div>
                </div>
                <div class="bg-surface-container-highest px-4 py-2">
                  <div class="text-[9px] text-outline uppercase font-bold">Nodes</div>
                  <div class="text-primary-fixed font-headline font-bold">1,024</div>
                </div>
              </div>
            </div>
            <div
              class="text-secondary-container opacity-0 group-hover:opacity-100 transition-all"
            >
              <span class="material-symbols-outlined text-4xl">arrow_outward</span>
            </div>
          </div>
        </div>
      </div>
      <!-- Project 2 -->
      <div
        class="md:col-span-4 group bg-surface-container-lowest border-2 border-surface-container p-6 hover:border-secondary-container transition-all"
      >
        <div class="flex justify-between items-start mb-12">
          <span class="material-symbols-outlined text-primary-fixed text-3xl">security</span>
          <span class="text-[10px] font-label text-outline uppercase">REF_392-A</span>
        </div>
        <h3
          class="text-xl font-bold font-headline text-on-surface uppercase mb-4 tracking-tighter"
        >
          Vault_Sentry OS
        </h3>
        <p class="text-on-surface-variant text-xs font-body mb-8 leading-relaxed">
          A hardened operating system kernel designed for cryptographic asset
          protection and hardware security modules.
        </p>
        <div class="space-y-3">
          <div class="flex justify-between items-center text-[10px] font-label border-b border-outline-variant pb-2">
            <span class="text-outline uppercase">Stack</span>
            <span class="text-on-surface">RUST / WEBASSEMBLY</span>
          </div>
          <div class="flex justify-between items-center text-[10px] font-label border-b border-outline-variant pb-2">
            <span class="text-outline uppercase">Outcome</span>
            <span class="text-on-surface">ZERO_BREACH_VALIDATED</span>
          </div>
        </div>
      </div>
      <!-- Project 3 -->
      <div
        class="md:col-span-4 group bg-surface-container-lowest border-2 border-surface-container p-6 hover:border-secondary-container transition-all"
      >
        <div class="flex justify-between items-start mb-12">
          <span class="material-symbols-outlined text-primary-fixed text-3xl">monitoring</span>
          <span class="text-[10px] font-label text-outline uppercase">REF_882-K</span>
        </div>
        <h3
          class="text-xl font-bold font-headline text-on-surface uppercase mb-4 tracking-tighter"
        >
          Specter Intelligence
        </h3>
        <p class="text-on-surface-variant text-xs font-body mb-8 leading-relaxed">
          Real-time visual telemetry dashboard for monitoring global logistics
          and supply chain disruptions.
        </p>
        <div class="space-y-3">
          <div class="flex justify-between items-center text-[10px] font-label border-b border-outline-variant pb-2">
            <span class="text-outline uppercase">Stack</span>
            <span class="text-on-surface">TYPESCRIPT / WEBGL</span>
          </div>
          <div class="flex justify-between items-center text-[10px] font-label border-b border-outline-variant pb-2">
            <span class="text-outline uppercase">Client</span>
            <span class="text-on-surface">COVERT_OPS_CMD</span>
          </div>
        </div>
      </div>
      <!-- Project 4 (Vertical Card) -->
      <div
        class="md:col-span-4 md:row-span-2 relative group overflow-hidden bg-[#0c0e12]"
      >
        <img
          alt="Hardware Circuits"
          class="absolute inset-0 w-full h-full object-cover opacity-30 group-hover:scale-110 transition-transform duration-700"
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuDn7_Wdox9pUZSdLt19HlQaTRgBQY1tXzqKYNRAOXx5x4yI5pJmA8DE6b7Bsu4O_MSNTzCMd99bEVUd-WQUTlQkHkhSpNyFSD6tTwHuuxN698aO23SgrxhJgVKG9RVmIfuJQVWXANcHibGzQLW40ulu_W-akjAkNyFyOE4DfAPZpQ0zZn3wLvvKDjauFS1hs9Y5aoFjwtvjs4RtQZA3BJ3tUSMR9tywbsj_hhOYOM7PcCpLGk81mTqMoRDYpzSJFjAQ-laMzu9O8WQ"
        />
        <div
          class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-surface-container-lowest z-10"
        ></div>
        <div class="relative z-20 h-full p-8 flex flex-col justify-end">
          <div
            class="mb-4 inline-block w-fit px-2 py-1 bg-secondary-container text-on-secondary-container font-bold text-[9px] uppercase tracking-widest"
          >
            CRITICAL_DEPLOYMENT
          </div>
          <h3
            class="text-2xl font-black font-headline text-on-surface uppercase tracking-tight mb-2"
          >
            Icarus_Engine
          </h3>
          <p class="text-on-surface-variant text-xs mb-6 leading-relaxed">
            The core thermal management architecture for next-gen data centers
            operating in sub-zero climates.
          </p>
          <button
            class="w-full py-4 border-2 border-primary-fixed text-primary-fixed font-bold text-[10px] tracking-[0.2em] uppercase hover:bg-primary-fixed hover:text-on-primary-fixed transition-colors"
          >
            VIEW_DATA_PACKET
          </button>
        </div>
      </div>
      <!-- Project 5 (Horizontal Data Rich) -->
      <div
        class="md:col-span-4 group bg-surface-container-low p-6 flex flex-col justify-between hover:bg-surface-container transition-colors"
      >
        <div>
          <div class="flex items-center space-x-2 mb-6">
            <span class="material-symbols-outlined text-outline">memory</span>
            <span class="text-xs font-label text-outline uppercase font-bold tracking-widest">CORE_SYS</span>
          </div>
          <h3
            class="text-lg font-bold font-headline text-on-surface uppercase tracking-tighter mb-2"
          >
            Synth_Voice Alpha
          </h3>
          <p class="text-on-surface-variant text-[11px] leading-tight">
            Neural-linguistic processing unit for encrypted VOIP communications.
          </p>
        </div>
        <div class="mt-8">
          <div class="flex items-end justify-between">
            <div class="flex -space-x-1">
              <div class="w-6 h-6 rounded-full border-2 border-surface-container-low bg-surface-container-high"></div>
              <div class="w-6 h-6 rounded-full border-2 border-surface-container-low bg-primary-container"></div>
              <div class="w-6 h-6 rounded-full border-2 border-surface-container-low bg-outline"></div>
            </div>
            <span class="text-[9px] font-label text-primary-fixed bg-primary-fixed/10 px-2 py-1">STABLE_V1.2</span>
          </div>
        </div>
      </div>
      <!-- Project 6 (Large Technical Detail) -->
      <div
        class="md:col-span-8 bg-surface-container-lowest border-2 border-surface-container overflow-hidden group"
      >
        <div class="flex flex-col md:flex-row h-full">
          <div class="md:w-1/2 p-8 border-b md:border-b-0 md:border-r border-surface-container">
            <div class="text-[10px] font-label text-outline uppercase mb-8">
              CASE_STUDY // 0042
            </div>
            <h3
              class="text-3xl font-black font-headline text-on-surface uppercase leading-none mb-4"
            >
              Void_Watcher
            </h3>
            <p class="text-on-surface-variant text-sm mb-6 leading-relaxed">
              Deep-space signal detection software. Filtering cosmic
              background noise to identify non-random patterns in the 40-60GHz range.
            </p>
            <div class="grid grid-cols-2 gap-4">
              <div class="recessed-well bg-surface-container-low p-3">
                <div class="text-[8px] text-outline uppercase mb-1">Compute_Load</div>
                <div class="text-on-surface font-headline font-bold">14.2 TFLOPS</div>
              </div>
              <div class="recessed-well bg-surface-container-low p-3">
                <div class="text-[8px] text-outline uppercase mb-1">Signal_Ratio</div>
                <div class="text-primary-fixed font-headline font-bold">99.8%</div>
              </div>
            </div>
          </div>
          <div class="md:w-1/2 bg-surface-container relative">
            <img
              alt="Cosmic Visualization"
              class="w-full h-full object-cover grayscale opacity-40 group-hover:grayscale-0 transition-all duration-700"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuColH8V4G-KyZAzqS98nFl4HxOK_l4ehmfgYrTwsfajJD-PuEXtAdI-tPDcV3A2xO3HTJeNYpnrHYxYWtVGUzLupXh8MhmvHq56My2SdsKcTZRut2ZERUyo5gjWC8ubB2zu7YgZm7mh6PWFmc6Jcd-ZdTh00gsoOYPZ3wELpQIplLAkb1exI9SzARs4VhCwnyNu5PZu1r4750-9OiJk7ymGlq-MoYmR6byj7WjG6P23bco7TyFtWVDIjit5ELVK66wrB_HfNt4C57E"
            />
            <div class="absolute inset-0 flex items-center justify-center">
              <button
                class="bg-surface-container-lowest/80 backdrop-blur-md p-4 rounded-full border border-primary-fixed/50 hover:scale-110 transition-transform"
              >
                <span class="material-symbols-outlined text-primary-fixed text-4xl">play_circle</span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- Terminal Status Footer -->
    <div
      class="mt-24 p-6 bg-surface-container-lowest border-2 border-surface-container flex flex-col md:flex-row justify-between items-center gap-4"
    >
      <div class="flex items-center space-x-6 text-[10px] font-label text-outline uppercase">
        <div class="flex items-center space-x-2">
          <span class="text-primary-fixed">UPTIME:</span>
          <span class="text-on-surface">342:11:04</span>
        </div>
        <div class="flex items-center space-x-2">
          <span class="text-primary-fixed">CONN:</span>
          <span class="text-on-surface">ENCRYPTED_AES256</span>
        </div>
      </div>
      <div class="flex items-center space-x-2">
        <span class="text-[9px] text-outline font-label uppercase">DOWNLOAD_EXPERIMENTS.PDF</span>
        <span class="material-symbols-outlined text-secondary-container">download</span>
      </div>
    </div>
  </main>
</Layout>
