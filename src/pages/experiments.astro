---
import Layout from '../layouts/Layout.astro';

type Experiment = {
  title: string
  date: string
  description: string
  status: "active" | "inactive"
}

const experiments: Experiment[] = [
];
---

<Layout title="Experiments">
	<section class="experiments">
		<h1>AI Experiments</h1>
		<p class="intro-text">
			A collection of explorations at the frontier of AI-assisted development.
			Each experiment represents a journey into what's possible when human creativity
			meets machine intelligence.
		</p>

		<div class="experiment-list">
			{experiments.map((experiment) => (
				<article class="experiment-item">
					<header>
						<h2>{experiment.title}</h2>
						<div class="meta">
							<time>{experiment.date}</time>
							<span class={`status status-${experiment.status}`}>
								{experiment.status}
							</span>
						</div>
					</header>
					<p>{experiment.description}</p>
				</article>
			))}
		</div>
	</section>
</Layout>

<style>
	.experiments h1 {
		color: var(--accent-color);
		font-family: var(--font-mono);
		font-size: 1.75rem;
		margin-bottom: 1.5rem;
	}

	.intro-text {
		margin-bottom: 3rem;
		font-size: 1.05rem;
		line-height: 1.7;
		max-width: 650px;
		color: var(--text-color);
		opacity: 0.9;
	}

	.experiment-list {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}

	.experiment-item {
		padding-bottom: 2rem;
		border-bottom: 1px solid var(--border-color);
	}

	.experiment-item:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}

	.experiment-item header {
		margin-bottom: 1rem;
	}

	.experiment-item h2 {
		font-size: 1.25rem;
		font-weight: 500;
		margin: 0 0 0.5rem 0;
		color: var(--text-color);
	}

	.meta {
		display: flex;
		align-items: center;
		gap: 1rem;
		font-family: var(--font-mono);
		font-size: 0.875rem;
	}

	.meta time {
		color: var(--text-color);
		opacity: 0.6;
	}

	.status {
		padding: 0.125rem 0.5rem;
		border-radius: 0.25rem;
		font-size: 0.75rem;
		text-transform: uppercase;
		font-weight: 600;
		letter-spacing: 0.05em;
	}

	.status-active {
		color: var(--accent-color);
		background-color: rgba(0, 255, 65, 0.1);
		border: 1px solid var(--accent-color);
	}

	.status-completed {
		color: var(--text-color);
		background-color: rgba(230, 232, 236, 0.1);
		border: 1px solid rgba(230, 232, 236, 0.3);
	}

	.status-archived {
		color: var(--text-color);
		opacity: 0.5;
		background-color: transparent;
		border: 1px solid rgba(230, 232, 236, 0.2);
	}

	.experiment-item p {
		line-height: 1.7;
		color: var(--text-color);
		opacity: 0.85;
	}

	@media (max-width: 640px) {
		.experiment-list {
			gap: 2rem;
		}

		.experiment-item h2 {
			font-size: 1.125rem;
		}
	}
</style>
