---
export interface Props {
	title: string;
	activeNav?: string;
	bodyClass?: string;
}

const { title, activeNav = '', bodyClass = '' } = Astro.props;
---

<!doctype html>
<html class="dark" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <meta name="description" content="Personal website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
    <script is:inline id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "surface-container": "#1e2024",
              "on-primary-fixed": "#00210b",
              "on-tertiary": "#20333c",
              error: "#ffb4ab",
              "on-primary": "#003917",
              "primary-container": "#00ff7f",
              "on-surface-variant": "#b9cbb8",
              "outline-variant": "#3b4b3c",
              "surface-container-highest": "#333539",
              "on-tertiary-fixed-variant": "#364953",
              "surface-container-low": "#1a1c20",
              "tertiary-container": "#cde1ee",
              "surface-dim": "#111317",
              "inverse-on-surface": "#2f3035",
              "on-secondary-container": "#521a00",
              "on-secondary": "#591c00",
              "on-primary-container": "#007134",
              "error-container": "#93000a",
              "on-secondary-fixed": "#370e00",
              "surface-bright": "#37393e",
              background: "#111317",
              "inverse-primary": "#006d33",
              tertiary: "#f7fbff",
              "on-error-container": "#ffdad6",
              "secondary-container": "#fe5f00",
              "on-surface": "#e2e2e8",
              "secondary-fixed-dim": "#ffb598",
              "inverse-surface": "#e2e2e8",
              primary: "#f0ffed",
              "surface-tint": "#00e471",
              "primary-fixed-dim": "#00e471",
              "tertiary-fixed-dim": "#b5cad6",
              "on-error": "#690005",
              "surface-variant": "#333539",
              secondary: "#ffb598",
              "surface-container-lowest": "#0c0e12",
              outline: "#849584",
              "on-tertiary-container": "#51646f",
              "on-tertiary-fixed": "#0a1e27",
              "on-primary-fixed-variant": "#005224",
              "on-background": "#e2e2e8",
              "on-secondary-fixed-variant": "#7e2c00",
              "tertiary-fixed": "#d1e6f2",
              "secondary-fixed": "#ffdbce",
              surface: "#111317",
              "primary-fixed": "#63ff93",
              "surface-container-high": "#282a2e",
            },
            fontFamily: {
              headline: ["Space Grotesk"],
              body: ["Space Grotesk"],
              label: ["Space Grotesk"],
            },
            borderRadius: {
              DEFAULT: "0.125rem",
              lg: "0.25rem",
              xl: "0.5rem",
              full: "0.75rem",
            },
          },
        },
      };
    </script>
    <style is:global>
      .material-symbols-outlined {
        font-variation-settings:
          "FILL" 0,
          "wght" 400,
          "GRAD" 0,
          "opsz" 24;
        vertical-align: middle;
      }
      body {
        font-family: "Space Grotesk", sans-serif;
      }
    </style>
    <slot name="head" />
  </head>
  <body
    class:list={[
      "bg-background text-on-background selection:bg-primary-container selection:text-on-primary-container overflow-x-hidden min-h-screen flex flex-col",
      bodyClass
    ]}
  >
    <!-- NAVIGATION -->
    <header
      class="fixed top-0 left-0 w-full z-50 bg-[#111317] border-b-2 border-[#1e2024] flex justify-between items-center px-6 py-4"
    >
      <div class="flex items-center gap-8">
        <a href="/" class="text-xl font-black text-[#00FF7F] tracking-widest font-headline no-underline hover:no-underline">TACTICAL_TERMINAL</a>
        <nav class="hidden md:flex gap-6 items-center">
          <a
            class:list={[
              "font-['Space_Grotesk'] tracking-tighter uppercase text-xs font-bold transition-colors",
              activeNav === 'home'
                ? "text-[#00FF7F] border-b-2 border-[#00FF7F] pb-1"
                : "text-[#b9cbb8] hover:text-[#00FF7F]"
            ]}
            href="/"
          >DASHBOARD</a>
          <a
            class:list={[
              "font-['Space_Grotesk'] tracking-tighter uppercase text-xs font-bold transition-colors",
              activeNav === 'experiments'
                ? "text-[#00FF7F] border-b-2 border-[#00FF7F] pb-1"
                : "text-[#b9cbb8] hover:text-[#00FF7F]"
            ]}
            href="/experiments"
          >EXPERIMENTS</a>
          <a
            class:list={[
              "font-['Space_Grotesk'] tracking-tighter uppercase text-xs font-bold transition-colors",
              activeNav === 'writings'
                ? "text-[#00FF7F] border-b-2 border-[#00FF7F] pb-1"
                : "text-[#b9cbb8] hover:text-[#00FF7F]"
            ]}
            href="/writings"
          >LOGS</a>
        </nav>
      </div>
      <div class="flex items-center gap-4">
        <span
          class="material-symbols-outlined text-[#b9cbb8] hover:bg-[#1e2024] p-2 transition-all cursor-pointer"
        >settings_input_component</span>
        <span
          class="material-symbols-outlined text-[#b9cbb8] hover:bg-[#1e2024] p-2 transition-all cursor-pointer"
        >terminal</span>
      </div>
    </header>

    <slot />

    <!-- FOOTER -->
    <footer
      class="w-full py-6 px-8 flex flex-col md:flex-row justify-between items-center bg-[#0c0e12] border-t-2 border-[#1e2024] relative z-20 gap-4 mt-auto"
    >
      <div
        class="font-['Space_Grotesk'] text-[9px] leading-none uppercase text-[#b9cbb8]"
      >
        &copy; 2024 SOVEREIGN_CONSOLE // KERNEL_VER: 4.2.0-STABLE
      </div>
      <div class="flex gap-8">
        <a
          class="font-['Space_Grotesk'] text-[9px] leading-none uppercase text-[#b9cbb8] hover:text-[#fe5f00] transition-colors focus:ring-1 focus:ring-[#fe5f00] outline-none"
          href="https://github.com/gvc"
        >GITHUB</a>
        <a
          class="font-['Space_Grotesk'] text-[9px] leading-none uppercase text-[#b9cbb8] hover:text-[#fe5f00] transition-colors focus:ring-1 focus:ring-[#fe5f00] outline-none"
          href="https://linkedin.com"
        >LINKEDIN</a>
      </div>
    </footer>

    <!-- MOBILE NAVIGATION -->
    <nav
      class="md:hidden fixed bottom-0 left-0 w-full bg-[#111317] flex justify-around items-center py-4 z-[60] border-t border-[#1e2024]"
    >
      <a class:list={["flex flex-col items-center gap-1", activeNav === 'home' ? "text-[#00FF7F]" : "text-[#b9cbb8]"]} href="/">
        <span class="material-symbols-outlined">grid_view</span>
        <span class="text-[8px] uppercase tracking-tighter font-bold">HOME</span>
      </a>
      <a class:list={["flex flex-col items-center gap-1", activeNav === 'experiments' ? "text-[#00FF7F]" : "text-[#b9cbb8]"]} href="/experiments">
        <span class="material-symbols-outlined">account_tree</span>
        <span class="text-[8px] uppercase tracking-tighter font-bold">WORK</span>
      </a>
      <a class:list={["flex flex-col items-center gap-1", activeNav === 'writings' ? "text-[#00FF7F]" : "text-[#b9cbb8]"]} href="/writings">
        <span class="material-symbols-outlined">terminal</span>
        <span class="text-[8px] uppercase tracking-tighter font-bold">LOGS</span>
      </a>
    </nav>
  </body>
</html>
