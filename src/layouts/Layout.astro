---
import '../styles/global.css';

export interface Props {
	title: string;
	activeNav?: string;
	bodyClass?: string;
}

const { title, activeNav = '', bodyClass = '' } = Astro.props;
---

<!doctype html>
<html class="dark" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <meta name="description" content="Personal website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body
    class:list={[
      "bg-background text-on-background selection:bg-primary-container selection:text-on-primary-container overflow-x-hidden min-h-screen flex flex-col",
      bodyClass
    ]}
  >
    <!-- NAVIGATION -->
    <header
      class="fixed top-0 left-0 w-full z-50 bg-[#111317] border-b-2 border-[#1e2024] flex justify-between items-center px-6 py-4"
    >
      <div class="flex items-center gap-8">
        <a href="/" class="text-xl font-black text-[#00FF7F] tracking-widest font-headline no-underline hover:no-underline">~/gvc</a>
        <nav class="hidden md:flex gap-6 items-center">
          <a
            class:list={[
              "font-['Space_Grotesk'] tracking-tighter uppercase text-xs font-bold transition-colors",
              activeNav === 'home'
                ? "text-[#00FF7F] border-b-2 border-[#00FF7F] pb-1"
                : "text-[#b9cbb8] hover:text-[#00FF7F]"
            ]}
            href="/"
          >DASHBOARD</a>
          <a
            class:list={[
              "font-['Space_Grotesk'] tracking-tighter uppercase text-xs font-bold transition-colors",
              activeNav === 'experiments'
                ? "text-[#00FF7F] border-b-2 border-[#00FF7F] pb-1"
                : "text-[#b9cbb8] hover:text-[#00FF7F]"
            ]}
            href="/experiments"
          >EXPERIMENTS</a>
          <a
            class:list={[
              "font-['Space_Grotesk'] tracking-tighter uppercase text-xs font-bold transition-colors",
              activeNav === 'writings'
                ? "text-[#00FF7F] border-b-2 border-[#00FF7F] pb-1"
                : "text-[#b9cbb8] hover:text-[#00FF7F]"
            ]}
            href="/writings"
          >LOGS</a>
          <a
            class:list={[
              "font-['Space_Grotesk'] tracking-tighter uppercase text-xs font-bold transition-colors",
              activeNav === 'who-am-i'
                ? "text-[#00FF7F] border-b-2 border-[#00FF7F] pb-1"
                : "text-[#b9cbb8] hover:text-[#00FF7F]"
            ]}
            href="/who-am-i"
          >WHO_AM_I</a>
        </nav>
      </div>
      <!-- <div class="flex items-center gap-4"> -->
      <!--   <span -->
      <!--     class="material-symbols-outlined text-[#b9cbb8] hover:bg-[#1e2024] p-2 transition-all cursor-pointer" -->
      <!--   >settings_input_component</span> -->
      <!--   <span -->
      <!--     class="material-symbols-outlined text-[#b9cbb8] hover:bg-[#1e2024] p-2 transition-all cursor-pointer" -->
      <!--   >terminal</span> -->
      <!-- </div> -->
    </header>

    <slot />

    <!-- FOOTER -->
    <footer
      class="w-full py-6 px-8 flex flex-col md:flex-row justify-between items-center bg-[#0c0e12] border-t-2 border-[#1e2024] relative z-20 gap-4 mt-auto"
    >
      <div class="flex flex-col gap-1">
        <div
          class="font-['Space_Grotesk'] text-[9px] leading-none uppercase text-[#b9cbb8]"
        >
          &copy; 2026 GUILHERME CARVALHO
        </div>
        <div
          class="font-['Space_Grotesk'] text-[9px] leading-none uppercase text-[#b9cbb8]/50"
        >
          Assembled with available tools
        </div>
      </div>
      <div class="flex gap-8">
        <a
          class="font-['Space_Grotesk'] text-[9px] leading-none uppercase text-[#b9cbb8] hover:text-[#fe5f00] transition-colors focus:ring-1 focus:ring-[#fe5f00] outline-none"
          href="https://github.com/gvc"
        >GITHUB</a>
        <a
          class="font-['Space_Grotesk'] text-[9px] leading-none uppercase text-[#b9cbb8] hover:text-[#fe5f00] transition-colors focus:ring-1 focus:ring-[#fe5f00] outline-none"
          href="https://www.linkedin.com/in/guieevc/"
        >LINKEDIN</a>
        <a
          class="font-['Space_Grotesk'] text-[9px] leading-none uppercase text-[#b9cbb8] hover:text-[#fe5f00] transition-colors focus:ring-1 focus:ring-[#fe5f00] outline-none"
          href="https://x.com/guieevc"
        >TWITTER</a>
      </div>
    </footer>

    <!-- MOBILE NAVIGATION -->
    <nav
      class="md:hidden fixed bottom-0 left-0 w-full bg-[#111317] flex justify-around items-center py-4 z-[60] border-t border-[#1e2024]"
    >
      <a class:list={["flex flex-col items-center gap-1", activeNav === 'home' ? "text-[#00FF7F]" : "text-[#b9cbb8]"]} href="/">
        <span class="material-symbols-outlined">grid_view</span>
        <span class="text-[8px] uppercase tracking-tighter font-bold">HOME</span>
      </a>
      <a class:list={["flex flex-col items-center gap-1", activeNav === 'experiments' ? "text-[#00FF7F]" : "text-[#b9cbb8]"]} href="/experiments">
        <span class="material-symbols-outlined">account_tree</span>
        <span class="text-[8px] uppercase tracking-tighter font-bold">WORK</span>
      </a>
      <a class:list={["flex flex-col items-center gap-1", activeNav === 'writings' ? "text-[#00FF7F]" : "text-[#b9cbb8]"]} href="/writings">
        <span class="material-symbols-outlined">terminal</span>
        <span class="text-[8px] uppercase tracking-tighter font-bold">LOGS</span>
      </a>
      <a class:list={["flex flex-col items-center gap-1", activeNav === 'who-am-i' ? "text-[#00FF7F]" : "text-[#b9cbb8]"]} href="/who-am-i">
        <span class="material-symbols-outlined">person</span>
        <span class="text-[8px] uppercase tracking-tighter font-bold">ID</span>
      </a>
    </nav>
  </body>
</html>
