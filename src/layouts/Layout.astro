---
export interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Personal website" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header>
			<nav>
				<a href="/" class="nav-link">home</a>
				<a href="/experiments" class="nav-link">experiments</a>
				<a href="/writings" class="nav-link">writings</a>
			</nav>
		</header>
		<main>
			<slot />
		</main>
	</body>
</html>

<style is:global>
	:root {
		--bg-color: #0A0E1B;
		--text-color: #E6E8EC;
		--accent-color: #00FF41;
		--accent-hover: #00CC33;
		--border-color: #1A1F2E;
		--code-bg: #0D1117;
		--font-mono: 'JetBrains Mono', 'Courier New', monospace;
		--font-sans: 'Inter', system-ui, -apple-system, sans-serif;
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html {
		font-family: var(--font-sans);
		font-size: 16px;
		line-height: 1.6;
		background-color: var(--bg-color);
		color: var(--text-color);
	}

	body {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	header {
		padding: 2rem 0;
		border-bottom: 1px solid var(--border-color);
	}

	nav {
		max-width: 800px;
		margin: 0 auto;
		padding: 0 1.5rem;
		display: flex;
		gap: 2rem;
	}

	.nav-link {
		font-family: var(--font-mono);
		font-size: 0.95rem;
		font-weight: 500;
		color: var(--accent-color);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.nav-link:hover {
		color: var(--accent-hover);
		text-decoration: underline;
	}

	main {
		max-width: 800px;
		width: 100%;
		margin: 0 auto;
		padding: 3rem 1.5rem;
		flex: 1;
	}

	h1 {
		font-size: 2rem;
		font-weight: 600;
		margin-bottom: 1.5rem;
		color: var(--text-color);
	}

	h2 {
		font-size: 1.5rem;
		font-weight: 600;
		margin-top: 2rem;
		margin-bottom: 1rem;
		color: var(--text-color);
	}

	h3 {
		font-size: 1.25rem;
		font-weight: 500;
		margin-top: 1.5rem;
		margin-bottom: 0.75rem;
		color: var(--text-color);
	}

	p {
		margin-bottom: 1rem;
		line-height: 1.7;
	}

	a {
		color: var(--accent-color);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	a:hover {
		color: var(--accent-hover);
		text-decoration: underline;
	}

	code {
		font-family: var(--font-mono);
		background-color: var(--code-bg);
		padding: 0.125rem 0.375rem;
		border-radius: 0.25rem;
		font-size: 0.9em;
	}

	pre {
		background-color: var(--code-bg);
		padding: 1rem;
		border-radius: 0.375rem;
		overflow-x: auto;
		margin-bottom: 1rem;
	}

	pre code {
		background: none;
		padding: 0;
	}

	@media (max-width: 640px) {
		nav {
			gap: 1.5rem;
			padding: 0 1rem;
		}

		main {
			padding: 2rem 1rem;
		}

		h1 {
			font-size: 1.75rem;
		}
	}
</style>